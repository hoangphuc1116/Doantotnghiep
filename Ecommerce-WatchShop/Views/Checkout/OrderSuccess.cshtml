﻿@{
    ViewData["Title"] = "Đặt hàng thành công";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-success text-white text-center">
                    <h3><i class="fa fa-check-circle"></i> Đặt hàng thành công!</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-success">
                        <strong>Cảm ơn bạn đã đặt hàng!</strong> Đơn hàng của bạn đã được ghi nhận và sẽ được xử lý sớm nhất.
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <h5>Thông tin đơn hàng</h5>
                            <p><strong>Mã đơn hàng:</strong> #DH@(Model.MaHoaDon.ToString("D6"))</p>
                            <p><strong>Ngày đặt:</strong> @Model.NgayDatHang.ToString("dd/MM/yyyy HH:mm")</p>
                            @if (ViewBag.DiscountPercent != null && (decimal)ViewBag.DiscountPercent > 0)
                            {
                                <p><strong>Tạm tính:</strong> @(((double)ViewBag.OriginalAmount).ToString("#,0")) VND</p>
                                <p><strong>Giảm giá (@(ViewBag.DiscountPercent)%):</strong> <span class="text-success">-@(((double)ViewBag.DiscountAmount).ToString("#,0")) VND</span></p>
                            }
                            <p><strong>Tổng tiền:</strong> <span class="text-success fw-bold">@Model.TongTien.ToString("#,0") VND</span></p>
                            <p>
                                <strong>Trạng thái:</strong>
                                @switch (Model.TrangThai)
                                {
                                    case 0:
                                        <span class="badge bg-danger">Đã hủy</span>
                                        break;
                                    case 1:
                                        <span class="badge bg-warning">Chờ xác nhận</span>
                                        break;
                                    case 2:
                                        <span class="badge bg-info">Đang xử lý</span>
                                        break;
                                    case 3:
                                        <span class="badge bg-primary">Đang giao</span>
                                        break;
                                    case 4:
                                        <span class="badge bg-success">Đã giao</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">Không xác định</span>
                                        break;
                                }
                            </p>
                        </div>
                        <div class="col-md-6">
                            <h5>Thông tin giao hàng</h5>
                            <p><strong>Người nhận:</strong> @Model.HoTen</p>
                            <p><strong>Số điện thoại:</strong> @Model.SoDienThoai</p>
                            <p><strong>Email:</strong> @Model.Email</p>
                            <p><strong>Địa chỉ:</strong> @Model.DiaChi</p>
                            @if (!string.IsNullOrEmpty(Model.Xa) || !string.IsNullOrEmpty(Model.Huyen) || !string.IsNullOrEmpty(Model.Tinh))
                            {
                                <p><strong>Khu vực:</strong> @Model.Xa, @Model.Huyen, @Model.Tinh</p>
                            }
                        </div>
                    </div>

                    <hr>

                    <h5>Chi tiết đơn hàng</h5>
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th>Số lượng</th>
                                    <th>Đơn giá</th>
                                    <th>Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.ChiTietHoaDons)
                                {
                                    <tr>
                                        <td>@item.SanPham.TenSanPham</td>
                                        <td>@item.SoLuong</td>
                                        <td>@item.Gia.ToString("#,0") VND</td>
                                        <td>@item.TongTien.ToString("#,0") VND</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" class="text-end"><strong>Phí giao hàng:</strong></td>
                                    <td><strong>30,000 VND</strong></td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end"><strong>Tổng cộng:</strong></td>
                                    <td><strong class="text-success">@Model.TongTien.ToString("#,0") VND</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">
                            <i class="fa fa-home"></i> Về trang chủ
                        </a>

                        @if (Model.TrangThai == 0)
                        {
                            <button type="button" class="btn btn-danger" onclick="showCancelModal(@Model.MaHoaDon)" style="background-color:#eb1313; border-color:#eb1313">
                                <i class="fa fa-times"></i> Hủy đơn hàng
                            </button>
                        }
                        else if (Model.TrangThai == 4)
                        {
                            <div class="alert alert-danger mb-0">
                                <i class="fa fa-times-circle"></i> Đơn hàng đã bị hủy
                                @if (!string.IsNullOrEmpty(Model.YeuCauHuy))
                                {
                                    <br><strong>Lý do:</strong> @Model.YeuCauHuy
                                    <br><strong>Ngày hủy:</strong> @Model.NgayYeuCauHuy?.ToString("dd/MM/yyyy HH:mm")
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mb-0">
                                <i class="fa fa-info-circle"></i> Đơn hàng đã được xác nhận, không thể hủy.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Hủy Đơn Hàng -->
<div class="modal fade" id="cancelOrderModal" tabindex="-1" aria-labelledby="cancelOrderModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="cancelOrderModalLabel">Hủy Đơn Hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="cancelOrderForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="cancelOrderId" name="id" />
                    <div class="alert alert-warning mb-3">
                        <i class="fa fa-exclamation-triangle"></i> 
                        <strong>Lưu ý:</strong> Bạn chỉ có thể hủy đơn hàng khi đơn hàng chưa được xác nhận.
                    </div>
                    <div class="mb-3">
                        <label for="cancelReason" class="form-label">Vui lòng chọn lý do hủy đơn: <span class="text-danger">*</span></label>
                        <select class="form-select" id="cancelReason" name="reason" required>
                            <option value="">-- Chọn lý do --</option>
                            <option value="Tôi muốn thay đổi địa chỉ giao hàng">Tôi muốn thay đổi địa chỉ giao hàng</option>
                            <option value="Tôi muốn thay đổi sản phẩm">Tôi muốn thay đổi sản phẩm</option>
                            <option value="Tôi tìm thấy giá rẻ hơn ở nơi khác">Tôi tìm thấy giá rẻ hơn ở nơi khác</option>
                            <option value="Tôi đổi ý, không muốn mua nữa">Tôi đổi ý, không muốn mua nữa</option>
                            <option value="Thời gian giao hàng quá lâu">Thời gian giao hàng quá lâu</option>
                            <option value="Đặt nhầm sản phẩm">Đặt nhầm sản phẩm</option>
                            <option value="Lý do khác">Lý do khác</option>
                        </select>
                    </div>
                    <div class="mb-3" id="otherReasonDiv" style="display: none;">
                        <label for="otherReason" class="form-label">Nhập lý do khác:</label>
                        <textarea class="form-control" id="otherReason" rows="3" placeholder="Vui lòng nhập lý do..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-danger" onclick="submitCancelOrder()">Xác nhận hủy</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Hiển thị modal hủy đơn
        function showCancelModal(orderId) {
            $('#cancelOrderId').val(orderId);
            $('#cancelReason').val('');
            $('#otherReason').val('');
            $('#otherReasonDiv').hide();
            var modal = new bootstrap.Modal(document.getElementById('cancelOrderModal'));
            modal.show();
        }

        // Hiển thị textarea khi chọn "Lý do khác"
        $(document).ready(function() {
            $('#cancelReason').on('change', function() {
                if ($(this).val() === 'Lý do khác') {
                    $('#otherReasonDiv').show();
                    $('#otherReason').focus();
                } else {
                    $('#otherReasonDiv').hide();
                }
            });
        });

        // Submit form hủy đơn
        function submitCancelOrder() {
            var orderId = $('#cancelOrderId').val();
            var reason = $('#cancelReason').val();
            
            if (!reason) {
                alert('Vui lòng chọn lý do hủy đơn!');
                return;
            }

            // Nếu chọn "Lý do khác", lấy nội dung từ textarea
            if (reason === 'Lý do khác') {
                var otherReason = $('#otherReason').val().trim();
                if (!otherReason) {
                    alert('Vui lòng nhập lý do hủy đơn!');
                    return;
                }
                reason = 'Lý do khác: ' + otherReason;
            }

            // Gửi AJAX request
            $.ajax({
                url: '@Url.Action("CancelOrder", "Account")',
                type: 'POST',
                data: {
                    id: orderId,
                    reason: reason,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        alert(response.message);
                        location.reload();
                    } else {
                        alert(response.message);
                    }
                },
                error: function() {
                    alert('Có lỗi xảy ra! Vui lòng thử lại.');
                }
            });
        }
    </script>
}