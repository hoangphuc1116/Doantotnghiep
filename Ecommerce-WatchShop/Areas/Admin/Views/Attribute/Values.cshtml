@model Ecommerce_WatchShop.Models.ThuocTinhSanPham
@{
    ViewData["Title"] = "Quản lý Giá trị - " + Model.TenThuocTinh;
}

<div class="container-xl">
    <div class="row g-3 mb-4 align-items-center justify-content-between">
        <div class="col-auto">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Attribute")">Thuộc tính</a></li>
                    <li class="breadcrumb-item active">@Model.TenThuocTinh</li>
                </ol>
            </nav>
            <h1 class="app-page-title mb-0">Quản lý Giá trị: @Model.TenThuocTinh</h1>
            @if (!string.IsNullOrEmpty(Model.MoTa))
            {
                <p class="text-muted">@Model.MoTa</p>
            }
        </div>
        <div class="col-auto">
            <a href="@Url.Action("Index", "Attribute")" class="btn btn-secondary me-2">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addValueModal">
                <i class="bi bi-plus-circle"></i> Thêm Giá trị
            </button>
        </div>
    </div>

    <div class="app-card app-card-orders-table shadow-sm mb-5">
        <div class="app-card-body">
            <div class="table-responsive">
                <table class="table app-table-hover mb-0 text-left">
                    <thead>
                        <tr>
                            <th class="cell">ID</th>
                            <th class="cell">Giá trị</th>
                            <th class="cell">Slug</th>
                            <th class="cell">Thứ tự</th>
                            <th class="cell">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.GiaTriThuocTinhs != null && Model.GiaTriThuocTinhs.Any())
                        {
                            foreach (var value in Model.GiaTriThuocTinhs)
                            {
                                <tr>
                                    <td class="cell">@value.MaGiaTri</td>
                                    <td class="cell"><strong>@value.GiaTri</strong></td>
                                    <td class="cell"><code>@value.Slug</code></td>
                                    <td class="cell">@value.ThuTuHienThi</td>
                                    <td class="cell">
                                        <button class="btn btn-sm btn-warning" onclick="editValue(@value.MaGiaTri, '@value.GiaTri', @value.ThuTuHienThi)" title="Sửa">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="btn btn-sm btn-danger" onclick="deleteValue(@value.MaGiaTri)" title="Xóa">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td class="cell text-center" colspan="5">Chưa có giá trị nào</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> 
        <strong>Hướng dẫn:</strong> Thêm các giá trị cụ thể cho thuộc tính "@Model.TenThuocTinh". 
        Ví dụ: Nếu thuộc tính là "RAM", các giá trị có thể là "8GB", "16GB", "32GB"...
    </div>
</div>

<!-- Modal Thêm Giá trị -->
<div class="modal fade" id="addValueModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Thêm Giá trị cho @Model.TenThuocTinh</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="addValueForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="MaThuocTinh" value="@Model.MaThuocTinh">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Giá trị <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="GiaTri" required placeholder="VD: Intel Core i5, 8GB, RTX 3060...">
                        <div class="form-text">Nhập giá trị cụ thể cho thuộc tính @Model.TenThuocTinh</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Thứ tự hiển thị</label>
                        <input type="number" class="form-control" name="ThuTuHienThi" value="0">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Thêm</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Sửa Giá trị -->
<div class="modal fade" id="editValueModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Sửa Giá trị</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editValueForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editMaGiaTri" name="MaGiaTri">
                <input type="hidden" name="MaThuocTinh" value="@Model.MaThuocTinh">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Giá trị <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="editGiaTri" name="GiaTri" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Thứ tự hiển thị</label>
                        <input type="number" class="form-control" id="editThuTuHienThi" name="ThuTuHienThi">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Thêm giá trị
            $('#addValueForm').on('submit', function (e) {
                e.preventDefault();
                $.ajax({
                    url: '@Url.Action("CreateValue", "Attribute")',
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function (response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert('Lỗi: ' + response.message);
                        }
                    },
                    error: function () {
                        alert('Có lỗi xảy ra!');
                    }
                });
            });

            // Sửa giá trị
            $('#editValueForm').on('submit', function (e) {
                e.preventDefault();
                $.ajax({
                    url: '@Url.Action("EditValue", "Attribute")',
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function (response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert('Lỗi: ' + response.message);
                        }
                    },
                    error: function () {
                        alert('Có lỗi xảy ra!');
                    }
                });
            });
        });

        function editValue(id, value, order) {
            $('#editMaGiaTri').val(id);
            $('#editGiaTri').val(value);
            $('#editThuTuHienThi').val(order);
            $('#editValueModal').modal('show');
        }

        function deleteValue(id) {
            if (confirm('Bạn có chắc muốn xóa giá trị này?')) {
                $.ajax({
                    url: '@Url.Action("DeleteValue", "Attribute")',
                    type: 'POST',
                    data: { 
                        id: id,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert('Lỗi: ' + response.message);
                        }
                    },
                    error: function () {
                        alert('Có lỗi xảy ra!');
                    }
                });
            }
        }
    </script>
}
