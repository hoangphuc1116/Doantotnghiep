@model IEnumerable<Ecommerce_WatchShop.Models.SanPham>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<style>
    .product-image-thumb {
        width: 50px;
        height: 50px;
        object-fit: cover;
        border-radius: 4px;
        border: 1px solid #dee2e6;
    }

    .product-image-placeholder {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        color: #6c757d;
    }

    .product-name {
        font-weight: 500;
        color: #252930;
        max-width: 200px;
    }

    .brand-name {
        font-weight: 500;
        color: #5d6778;
    }

    .price {
        font-weight: 600;
        color: #15a362;
        font-size: 0.9rem;
    }

    .app-page-title {
        color: #252930;
        font-weight: 600;
    }

    .btn-group .btn {
        margin-right: 0;
    }

        .btn-group .btn:not(:last-child) {
            border-right: 0;
        }

        .btn-group .btn:not(:first-child) {
            border-left: 0;
        }
</style>

<div class="app-content pt-3 p-md-3 p-lg-4">
    <div class="container-xl">

        <div class="row g-3 mb-4 align-items-center justify-content-between">
            <div class="col-auto">
                <h1 class="app-page-title mb-0">@ViewData["Title"]</h1>
            </div>
            <div class="col-auto">
                <div class="page-utilities">
                    <div class="row g-2 justify-content-start justify-content-md-end align-items-center">
                        <div class="col-auto">
                            <a href="@Url.Action("Create", "Product", new { id = 0 })" class="btn app-btn-primary">
                                <svg width="1em" height="1em" viewBox="0 0 16 16" class="bi bi-plus me-2" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                    <path fill-rule="evenodd" d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z" />
                                </svg>
                                Thêm sản phẩm mới
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (TempData["success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <svg width="1em" height="1em" viewBox="0 0 16 16" class="bi bi-check-circle-fill me-2" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.061L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
                </svg>
                @TempData["success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <svg width="1em" height="1em" viewBox="0 0 16 16" class="bi bi-exclamation-triangle-fill me-2" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
                </svg>
                @TempData["error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="app-card app-card-orders-table shadow-sm mb-5">
            <div class="app-card-body">
                <div class="table-responsive">
                    <table class="table app-table-hover mb-0 text-left">
                        <thead>
                            <tr>
                                <th class="cell">ID</th>
                                <th class="cell">Hình ảnh</th>
                                <th class="cell">Tên sản phẩm</th>
                                <th class="cell">Danh mục</th>
                                <th class="cell">Thương hiệu</th>
                                <th class="cell">Giá</th>
                                <th class="cell">Số lượng</th>
                                <th class="cell">Trạng thái</th>
                                <th class="cell">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model)
                            {
                                <tr>
                                    <td class="cell">#@product.MaSanPham</td>
                                    <td class="cell">
                                        @if (!string.IsNullOrEmpty(product.HinhAnh))
                                        {
                                            <img src="@product.HinhAnh" alt="@product.TenSanPham" class="product-image-thumb" />
                                        }
                                        else
                                        {
                                            <div class="product-image-placeholder">
                                                <svg width="40" height="40" viewBox="0 0 16 16" class="bi bi-image" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                                    <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z" />
                                                    <path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2h-12zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1h12z" />
                                                </svg>
                                            </div>
                                        }
                                    </td>
                                    <td class="cell">
                                        <div class="product-name">@product.TenSanPham</div>
                                        @if (!string.IsNullOrEmpty(product.MoTaNgan))
                                        {
                                            <div class="note">@product.MoTaNgan</div>
                                        }
                                    </td>
                                    <td class="cell">
                                        <span class="badge bg-secondary">@(product.DanhMuc?.TenDanhMuc ?? "Chưa phân loại")</span>
                                    </td>
                                    <td class="cell">
                                        @if (product.ThuongHieu != null)
                                        {
                                            <span class="brand-name">@product.ThuongHieu.TenThuongHieu</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Chưa có</span>
                                        }
                                    </td>
                                    <td class="cell">
                                        <div class="price">@product.Gia.ToString("N0") VNĐ</div>
                                    </td>
                                    <td class="cell">
                                        <span class="badge @(product.SoLuong > 10 ? "bg-success" : product.SoLuong > 0 ? "bg-warning" : "bg-danger")">
                                            @product.SoLuong
                                        </span>
                                    </td>
                                    <td class="cell">
                                        @if (product.TrangThai == 1)
                                        {
                                            <span class="badge bg-success">
                                                <svg width="12" height="12" viewBox="0 0 16 16" class="bi bi-eye" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                                    <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z" />
                                                    <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z" />
                                                </svg>
                                                Hiển thị
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <svg width="12" height="12" viewBox="0 0 16 16" class="bi bi-eye-slash" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                                    <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755-.165.165-.337.328-.517.486l.708.709z" />
                                                    <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829l.822.822zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z" />
                                                    <path d="M3.35 5.47c-.18.16-.353.322-.518.487A13.134 13.134 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7.029 7.029 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12-.708.708z" />
                                                </svg>
                                                Ẩn
                                            </span>
                                        }
                                    </td>
                                    <td class="cell">
                                        <div class="btn-group" role="group">
                                            <a href="@Url.Action("Edit", "Product", new { id = product.MaSanPham })" class="btn btn-sm btn-outline-primary" title="Chỉnh sửa">
                                                <svg width="14" height="14" viewBox="0 0 16 16" class="bi bi-pencil" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                                    <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708L15.5 4.207l-3-3L12.146.146zM11.207 1.5L1.5 11.207V14.5h3.293L14.5 4.793 11.207 1.5z" />
                                                </svg>
                                            </a>

                                            @if (product.TrangThai == 1)
                                            {
                                                <form asp-action="HideProduct" asp-route-id="@product.MaSanPham" method="post" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-warning" title="Ẩn sản phẩm" onclick="return confirm('Bạn có chắc muốn ẩn sản phẩm này?')">
                                                        <svg width="14" height="14" viewBox="0 0 16 16" class="bi bi-eye-slash" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                                            <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755-.165.165-.337.328-.517.486l.708.709z" />
                                                            <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829l.822.822zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z" />
                                                            <path d="M3.35 5.47c-.18.16-.353.322-.518.487A13.134 13.134 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7.029 7.029 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12-.708.708z" />
                                                        </svg>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-action="ShowProduct" asp-route-id="@product.MaSanPham" method="post" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Hiển thị sản phẩm" onclick="return confirm('Bạn có chắc muốn hiển thị lại sản phẩm này?')">
                                                        <svg width="14" height="14" viewBox="0 0 16 16" class="bi bi-eye" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                                            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z" />
                                                            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z" />
                                                        </svg>
                                                    </button>
                                                </form>
                                            }

                                            <form asp-action="Delete" asp-route-id="@product.MaSanPham" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa sản phẩm" onclick="return confirm('Bạn có chắc muốn xóa vĩnh viễn sản phẩm này? Hành động này không thể hoàn tác!')">
                                                    <svg width="14" height="14" viewBox="0 0 16 16" class="bi bi-trash" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                                        <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z" />
                                                        <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z" />
                                                    </svg>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>


