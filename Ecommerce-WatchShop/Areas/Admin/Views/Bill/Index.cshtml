@model IEnumerable<Ecommerce_WatchShop.Models.HoaDon>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4 class="card-title mb-0">
                        <i class="fas fa-shopping-cart"></i>
                        Quản lý đơn hàng (@Model.Count() đơn hàng)
                    </h4>
                </div>
                <div class="card-body">
                    @if (TempData["success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i>
                            @TempData["success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <!-- Thống kê nhanh -->
                    <div class="row mb-4">
                        <div class="col-md-3">
                            <div class="stat-card bg-warning">
                                <div class="stat-icon">
                                    <i class="fas fa-clock"></i>
                                </div>
                                <div class="stat-content">
                                    <h4>@Model.Count(x => x.TrangThai == 0)</h4>
                                    <p>Chờ xác nhận</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stat-card bg-info">
                                <div class="stat-icon">
                                    <i class="fas fa-check"></i>
                                </div>
                                <div class="stat-content">
                                    <h4>@Model.Count(x => x.TrangThai == 1)</h4>
                                    <p>Đã xác nhận</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stat-card bg-primary">
                                <div class="stat-icon">
                                    <i class="fas fa-truck"></i>
                                </div>
                                <div class="stat-content">
                                    <h4>@Model.Count(x => x.TrangThai == 2)</h4>
                                    <p>Đang giao</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stat-card bg-success">
                                <div class="stat-icon">
                                    <i class="fas fa-check-circle"></i>
                                </div>
                                <div class="stat-content">
                                    <h4>@Model.Count(x => x.TrangThai == 3)</h4>
                                    <p>Hoàn thành</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Thống kê đơn hủy -->
                    @if (Model.Any(x => x.TrangThai == 4))
                    {
                        <div class="alert alert-danger mb-4">
                            <i class="fas fa-exclamation-triangle"></i>
                            <strong>Đơn hàng đã hủy:</strong> @Model.Count(x => x.TrangThai == 4) đơn
                            <a asp-action="Index" asp-route-status="4" class="btn btn-sm btn-outline-danger ms-2">Xem chi tiết</a>
                        </div>
                    }

                    <!-- Bộ lọc -->
                    <div class="filter-section mb-3">
                        <div class="row">
                            <div class="col-md-3">
                                <select class="form-select" id="statusFilter">
                                    <option value="">Tất cả trạng thái</option>
                                    <option value="0">Chờ xác nhận</option>
                                    <option value="1">Đã xác nhận</option>
                                    <option value="2">Đang giao</option>
                                    <option value="3">Hoàn thành</option>
                                    <option value="4">Đã hủy</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <input type="date" class="form-control" id="dateFilter" placeholder="Lọc theo ngày">
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control" id="searchFilter" placeholder="Tìm kiếm theo mã đơn hàng, tên khách hàng...">
                            </div>
                            <div class="col-md-2">
                                <button class="btn btn-secondary w-100" onclick="clearFilters()">
                                    <i class="fas fa-refresh"></i> Xóa bộ lọc
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Bảng đơn hàng -->
                    <div class="table-responsive">
                        <table class="table table-striped" id="ordersTable">
                            <thead class="table-dark">
                                <tr>
                                    <th>Mã đơn hàng</th>
                                    <th>Khách hàng</th>
                                    <th>Ngày đặt</th>
                                    <th>Tổng tiền</th>
                                    <th>Thanh toán</th>
                                    <th>Trạng thái</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var bill in Model)
                                    {
                                        <tr data-status="@bill.TrangThai" data-date="@bill.NgayDatHang.ToString("yyyy-MM-dd")" data-search="@($"DH{bill.MaHoaDon.ToString("D6")} {bill.HoTen} {bill.SoDienThoai}")">
                                            <td>
                                                <strong>#DH@(bill.MaHoaDon.ToString("D6"))</strong>
                                            </td>
                                            <td>
                                                <div class="customer-info">
                                                    <strong>@bill.HoTen</strong><br>
                                                    <small class="text-muted">
                                                        <i class="fas fa-phone"></i> @bill.SoDienThoai
                                                    </small>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="date-info">
                                                    <strong>@bill.NgayDatHang.ToString("dd/MM/yyyy")</strong><br>
                                                    <small class="text-muted">@bill.NgayDatHang.ToString("HH:mm")</small>
                                                </div>
                                            </td>
                                            <td>
                                                <strong class="text-success">@string.Format("{0:N0}", bill.TongTien) VNĐ</strong>
                                            </td>
                                            <td>
                                                @if (bill.PhuongThucThanhToan == "COD")
                                                {
                                                    <span class="badge bg-info">COD</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success">@bill.PhuongThucThanhToan</span>
                                                }
                                            </td>
                                            <td>
                                                @switch (bill.TrangThai)
                                                {
                                                    case 0:
                                                        <span class="badge bg-warning">Chờ xác nhận</span>
                                                        break;
                                                    case 1:
                                                        <span class="badge bg-info">Đã xác nhận</span>
                                                        break;
                                                    case 2:
                                                        <span class="badge bg-primary">Đang giao</span>
                                                        break;
                                                    case 3:
                                                        <span class="badge bg-success">Hoàn thành</span>
                                                        break;
                                                    case 4:
                                                        <div>
                                                            <span class="badge bg-danger">Đã hủy</span>
                                                            @if (!string.IsNullOrEmpty(bill.YeuCauHuy))
                                                            {
                                                                <br>
                                                                <small class="text-muted" title="@bill.YeuCauHuy">
                                                                    <i class="fas fa-info-circle"></i> 
                                                                    @(bill.YeuCauHuy.Length > 30 ? bill.YeuCauHuy.Substring(0, 30) + "..." : bill.YeuCauHuy)
                                                                </small>
                                                            }
                                                        </div>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">Không xác định</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                <div class="action-buttons">
                                                    <a asp-action="Details" asp-route-id="@bill.MaHoaDon" class="btn btn-primary btn-sm" title="Xem chi tiết">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    @if (bill.TrangThai != 4 && bill.TrangThai != 3)
                                                    {
                                                        <div class="btn-group">
                                                            <button type="button" class="btn btn-success btn-sm dropdown-toggle" data-bs-toggle="dropdown" title="Cập nhật trạng thái">
                                                                <i class="fas fa-edit"></i>
                                                            </button>
                                                            <ul class="dropdown-menu">
                                                                @if (bill.TrangThai == 0)
                                                                {
                                                                    <li>
                                                                        <a class="dropdown-item" href="#" onclick="updateStatus(@bill.MaHoaDon, 1)">
                                                                            <i class="fas fa-check text-info"></i> Xác nhận đơn hàng
                                                                        </a>
                                                                    </li>
                                                                    <li><hr class="dropdown-divider"></li>
                                                                }
                                                                @if (bill.TrangThai == 1)
                                                                {
                                                                    <li>
                                                                        <a class="dropdown-item" href="#" onclick="updateStatus(@bill.MaHoaDon, 2)">
                                                                            <i class="fas fa-truck text-primary"></i> Bắt đầu giao hàng
                                                                        </a>
                                                                    </li>
                                                                    <li><hr class="dropdown-divider"></li>
                                                                }
                                                                @if (bill.TrangThai == 2)
                                                                {
                                                                    <li>
                                                                        <a class="dropdown-item" href="#" onclick="updateStatus(@bill.MaHoaDon, 3)">
                                                                            <i class="fas fa-check-circle text-success"></i> Hoàn thành đơn hàng
                                                                        </a>
                                                                    </li>
                                                                    <li><hr class="dropdown-divider"></li>
                                                                }
                                                                <li>
                                                                    <a class="dropdown-item text-danger" href="#" onclick="confirmCancel(@bill.MaHoaDon)">
                                                                        <i class="fas fa-times"></i> Hủy đơn hàng
                                                                    </a>
                                                                </li>
                                                            </ul>
                                                        </div>
                                                    }
                                                    else if (bill.TrangThai == 4)
                                                    {
                                                        <span class="badge bg-secondary">Đã hủy</span>
                                                    }
                                                    else if (bill.TrangThai == 3)
                                                    {
                                                        <span class="badge bg-success">Hoàn thành</span>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center">
                                            <em>Chưa có đơn hàng nào</em>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .stat-card {
            border-radius: 10px;
            padding: 20px;
            color: white;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
        }

        .stat-icon {
            font-size: 2.5rem;
            margin-right: 15px;
            opacity: 0.8;
        }

        .stat-content h4 {
            margin: 0;
            font-size: 2rem;
            font-weight: 700;
        }

        .stat-content p {
            margin: 0;
            font-size: 0.9rem;
            opacity: 0.9;
        }

        .filter-section {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            border: 1px solid #dee2e6;
        }

        .customer-info, .date-info {
            line-height: 1.2;
        }

        .action-buttons {
            display: flex;
            gap: 5px;
        }

        .table th {
            background-color: #0d2a27;
            color: white;
            border: none;
        }

        .table-striped > tbody > tr:nth-of-type(odd) > td {
            background-color: #f8f9fa;
        }

        @@media (max-width: 768px) {
            .stat-card {
                text-align: center;
                flex-direction: column;
            }

            .stat-icon {
                margin-right: 0;
                margin-bottom: 10px;
            }
        }
    </style>
    <script>
        function updateStatus(orderId, status) {
            var statusText = '';
            switch(status) {
                case 1: statusText = 'xác nhận'; break;
                case 2: statusText = 'bắt đầu giao'; break;
                case 3: statusText = 'hoàn thành'; break;
                case 4: statusText = 'hủy'; break;
            }
            
            if (confirm('Bạn có chắc chắn muốn ' + statusText + ' đơn hàng này?')) {
                var form = document.createElement('form');
                form.method = 'post';
                form.action = '@Url.Action("UpdateStatus", "Bill")';

                var idInput = document.createElement('input');
                idInput.type = 'hidden';
                idInput.name = 'id';
                idInput.value = orderId;

                var statusInput = document.createElement('input');
                statusInput.type = 'hidden';
                statusInput.name = 'status';
                statusInput.value = status;

                form.appendChild(idInput);
                form.appendChild(statusInput);
                document.body.appendChild(form);
                form.submit();
            }
        }

        function confirmCancel(orderId) {
            if (confirm('Bạn có chắc chắn muốn HỦY đơn hàng này?\n\nLưu ý: Hành động này không thể hoàn tác!')) {
                updateStatus(orderId, 4);
            }
        }

        function clearFilters() {
            document.getElementById('statusFilter').value = '';
            document.getElementById('dateFilter').value = '';
            document.getElementById('searchFilter').value = '';
            filterTable();
        }

        function filterTable() {
            var statusFilter = document.getElementById('statusFilter').value;
            var dateFilter = document.getElementById('dateFilter').value;
            var searchFilter = document.getElementById('searchFilter').value.toLowerCase();
            var rows = document.querySelectorAll('#ordersTable tbody tr');

            rows.forEach(function(row) {
                var status = row.getAttribute('data-status');
                var date = row.getAttribute('data-date');
                var searchText = row.getAttribute('data-search').toLowerCase();

                var showRow = true;

                if (statusFilter && status !== statusFilter) {
                    showRow = false;
                }

                if (dateFilter && date !== dateFilter) {
                    showRow = false;
                }

                if (searchFilter && !searchText.includes(searchFilter)) {
                    showRow = false;
                }

                row.style.display = showRow ? '' : 'none';
            });
        }

        document.getElementById('statusFilter').addEventListener('change', filterTable);
        document.getElementById('dateFilter').addEventListener('change', filterTable);
        document.getElementById('searchFilter').addEventListener('input', filterTable);
    </script>
}